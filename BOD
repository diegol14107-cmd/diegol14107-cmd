<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BOD — CFO Virtual | Tu Aliado en Crecimiento</title>
  <meta name="description" content="BOD democratiza el acceso a herramientas financieras y asesoría estratégica mediante una plataforma digital inteligente de CFO virtual."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700;900&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #040408;
      --bg2:       #07070e;
      --navy:      #1a1a3e;
      --glass:     rgba(255,255,255,0.04);
      --glass-b:   rgba(255,255,255,0.08);
      --glass-h:   rgba(255,255,255,0.07);
      --muted:     rgba(255,255,255,0.42);
      --faint:     rgba(255,255,255,0.18);
      --white:     #ffffff;
      --purple:    #4d9fff;
      --purple-dim:rgba(77,159,255,0.12);
      --blue-logo: #1e2a8c;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--white);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 68px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 6%;
      background: rgba(4,4,8,0.8);
      backdrop-filter: blur(20px) saturate(160%);
      border-bottom: 1px solid var(--glass-b);
    }

    .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .nav-logo-img {
      height: 38px; width: auto;
      object-fit: contain;
      /* logo already white-on-black — renders natively on dark bg */
    }

    .nav-links { display: flex; gap: 2.4rem; list-style: none; }
    .nav-links a { font-size: 0.82rem; font-weight: 400; color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .nav-links a:hover { color: white; }

    .nav-cta {
      font-size: 0.82rem; font-weight: 600;
      background: white; color: var(--bg);
      padding: 0.5rem 1.3rem; border-radius: 7px;
      text-decoration: none; transition: opacity 0.2s, transform 0.15s;
    }
    .nav-cta:hover { opacity: 0.85; transform: translateY(-1px); }

    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .hamburger span { display: block; width: 22px; height: 1.5px; background: rgba(255,255,255,0.65); border-radius: 2px; }

    /* ── HERO (AetherFlow canvas) ── */
    #hero {
      position: relative; height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }

    #particle-canvas {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%;
    }

    /* Bottom fade so hero blends into next section */
    #hero::after {
      content: '';
      position: absolute; bottom: 0; left: 0; right: 0; height: 200px;
      background: linear-gradient(to bottom, transparent, var(--bg));
      pointer-events: none; z-index: 2;
    }

    .hero-content {
      position: relative; z-index: 3;
      text-align: center; padding: 0 5%;
      display: flex; flex-direction: column; align-items: center;
    }

    /* Animated entrance */
    .fade-up { opacity: 0; transform: translateY(20px); animation: fadeUp 0.8s ease forwards; }
    .fade-up-1 { animation-delay: 0.5s; }
    .fade-up-2 { animation-delay: 0.7s; }
    .fade-up-3 { animation-delay: 0.9s; }
    .fade-up-4 { animation-delay: 1.1s; }
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 16px; border-radius: 50px;
      background: rgba(77,159,255,0.1);
      border: 1px solid rgba(77,159,255,0.2);
      backdrop-filter: blur(8px);
      margin-bottom: 2rem;
    }
    .hero-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--purple); animation: blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1}50%{opacity:0.3} }
    .hero-badge-text { font-size: 0.75rem; font-weight: 500; color: rgba(255,255,255,0.75); letter-spacing: 0.5px; }

    /* Big logo in hero */
    .hero-logo {
      height: 90px; width: auto;
      margin-bottom: 2rem;
      filter: drop-shadow(0 0 40px rgba(191,128,255,0.25)) brightness(1.1);
    }

    .hero-h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(3rem, 7vw, 6rem);
      font-weight: 400; line-height: 1.0; letter-spacing: -1px;
      color: white; margin-bottom: 1.2rem;
      background: linear-gradient(to bottom, #ffffff, rgba(255,255,255,0.65));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-h1 em { font-style: italic; -webkit-text-fill-color: var(--purple); color: var(--purple); }

    .hero-sub {
      font-size: 1rem; font-weight: 300; line-height: 1.75;
      color: var(--muted); max-width: 520px; margin-bottom: 2.5rem;
    }

    .hero-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: white; color: var(--bg);
      font-size: 0.88rem; font-weight: 600;
      padding: 0.82rem 1.8rem; border-radius: 9px;
      text-decoration: none; border: none; cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
      box-shadow: 0 4px 24px rgba(255,255,255,0.1);
    }
    .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-primary svg { width: 16px; height: 16px; }

    .btn-ghost {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--glass); color: rgba(255,255,255,0.7);
      font-size: 0.88rem; font-weight: 400;
      padding: 0.82rem 1.8rem; border-radius: 9px;
      text-decoration: none; border: 1px solid var(--glass-b);
      backdrop-filter: blur(10px);
      transition: background 0.2s, border-color 0.2s, transform 0.15s;
    }
    .btn-ghost:hover { background: var(--glass-h); border-color: var(--faint); transform: translateY(-1px); }

    /* ── SECTION BASE ── */
    section { padding: 7rem 6%; }
    .container { max-width: 1200px; margin: 0 auto; }
    .eyebrow { font-size: 0.7rem; font-weight: 500; letter-spacing: 2.5px; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 1rem; }
    .sec-h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 400; letter-spacing: -0.5px; line-height: 1.1;
      color: white; margin-bottom: 1.2rem;
    }
    .sec-h2 em { font-style: italic; color: var(--purple); }
    .sec-p { font-size: 0.95rem; font-weight: 300; line-height: 1.8; color: var(--muted); max-width: 500px; }

    /* ── PROBLEM ── */
    #problem { background: var(--bg2); padding-top: 5rem; padding-bottom: 5rem; }

    .problem-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 1px;
      background: var(--glass-b);
      border-radius: 20px; overflow: hidden; border: 1px solid var(--glass-b);
    }
    .prob-item { background: var(--bg2); padding: 2.5rem 2rem; transition: background 0.3s; }
    .prob-item:hover { background: rgba(191,128,255,0.04); }
    .prob-num { font-size: 2.5rem; font-weight: 700; letter-spacing: -2px; color: rgba(191,128,255,0.08); line-height: 1; margin-bottom: 1rem; }
    .prob-title { font-size: 0.95rem; font-weight: 600; color: white; margin-bottom: 0.6rem; }
    .prob-desc { font-size: 0.83rem; font-weight: 300; line-height: 1.7; color: var(--muted); }

    /* ── SOLUTION ── */
    #solution { background: var(--bg); }

    .sol-intro {
      display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end;
      margin-bottom: 5rem; padding-bottom: 4rem; border-bottom: 1px solid var(--glass-b);
    }

    .sol-features { display: flex; flex-direction: column; gap: 1px; background: var(--glass-b); border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-b); }

    .sf-item {
      background: var(--bg); padding: 2.2rem 2rem;
      display: flex; gap: 1.5rem; align-items: flex-start;
      transition: background 0.3s; cursor: default;
    }
    .sf-item:hover { background: rgba(191,128,255,0.03); }

    .sf-icon {
      width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
      border: 1px solid var(--glass-b); background: var(--glass);
      display: flex; align-items: center; justify-content: center;
      transition: all 0.3s;
    }
    .sf-icon svg { width: 20px; height: 20px; fill: none; stroke: rgba(255,255,255,0.5); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; transition: stroke 0.3s; }
    .sf-item:hover .sf-icon { border-color: rgba(191,128,255,0.3); background: var(--purple-dim); }
    .sf-item:hover .sf-icon svg { stroke: var(--purple); }

    .sf-body h4 { font-size: 0.95rem; font-weight: 600; color: white; margin-bottom: 0.4rem; }
    .sf-body p { font-size: 0.83rem; font-weight: 300; line-height: 1.65; color: var(--muted); }

    /* ── HOW IT WORKS ── */
    #how { background: var(--bg2); }

    .how-header { text-align: center; margin-bottom: 5rem; }
    .how-header .sec-p { margin: 0 auto; }

    .how-steps { display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; position: relative; }
    .how-steps::before {
      content: ''; position: absolute; top: 22px; left: 10%; right: 10%; height: 1px;
      background: linear-gradient(90deg, transparent, var(--glass-b) 20%, var(--glass-b) 80%, transparent);
    }

    .how-step { text-align: center; padding: 0 0.5rem; }
    .how-step-num {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--glass); border: 1px solid var(--glass-b);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.78rem; font-weight: 700; color: var(--muted);
      margin: 0 auto 1.5rem; position: relative; z-index: 1;
      transition: all 0.3s;
    }
    .how-step:hover .how-step-num { background: var(--purple-dim); border-color: rgba(191,128,255,0.35); color: var(--purple); }
    .how-step-title { font-size: 0.9rem; font-weight: 600; color: white; margin-bottom: 0.5rem; }
    .how-step-desc { font-size: 0.8rem; font-weight: 300; line-height: 1.65; color: var(--muted); }

    /* ── METRICS ── */
    #metrics { background: var(--bg); padding: 4rem 6%; }
    .metrics-inner {
      max-width: 1200px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr);
      gap: 1px; background: var(--glass-b);
      border-radius: 20px; overflow: hidden; border: 1px solid var(--glass-b);
    }
    .metric-cell { background: var(--bg); padding: 2.5rem 2rem; text-align: center; transition: background 0.3s; }
    .metric-cell:hover { background: rgba(191,128,255,0.03); }
    .mc-num { font-family: 'DM Serif Display', serif; font-size: 2.8rem; font-weight: 400; letter-spacing: -1px; color: white; line-height: 1; }
    .mc-num em { font-style: italic; color: var(--purple); }
    .mc-label { font-size: 0.78rem; font-weight: 300; color: var(--muted); margin-top: 0.5rem; line-height: 1.5; }

    /* ── PRICING ── */
    #pricing { background: var(--bg2); }
    .pricing-header { text-align: center; margin-bottom: 4rem; }
    .pricing-header .sec-p { margin: 0 auto; }
    .pricing-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; }

    .plan {
      border-radius: 20px; padding: 2.5rem 2rem;
      border: 1px solid var(--glass-b); background: var(--glass);
      position: relative; overflow: hidden;
      transition: border-color 0.3s, transform 0.25s;
    }
    .plan:hover { border-color: var(--faint); transform: translateY(-4px); }
    .plan.featured { background: rgba(191,128,255,0.05); border-color: rgba(191,128,255,0.25); }
    .plan.featured:hover { border-color: rgba(191,128,255,0.45); }

    .plan-badge {
      display: inline-block; font-size: 0.65rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
      background: var(--purple-dim); color: var(--purple);
      border: 1px solid rgba(191,128,255,0.2);
      padding: 3px 10px; border-radius: 50px; margin-bottom: 1.5rem;
    }
    .plan-name { font-size: 0.75rem; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 0.5rem; }
    .plan-price { font-size: 2.6rem; font-weight: 700; letter-spacing: -2px; color: white; line-height: 1; }
    .plan-price span { font-size: 0.85rem; font-weight: 300; letter-spacing: 0; color: var(--muted); }
    .plan-desc { font-size: 0.82rem; font-weight: 300; color: var(--muted); margin: 0.8rem 0 1.5rem; line-height: 1.6; }
    .plan-divider { height: 1px; background: var(--glass-b); margin-bottom: 1.5rem; }
    .plan-features { display: flex; flex-direction: column; gap: 0.7rem; margin-bottom: 2rem; }
    .plan-feature { display: flex; gap: 0.7rem; align-items: flex-start; font-size: 0.82rem; font-weight: 300; color: rgba(255,255,255,0.65); line-height: 1.4; }
    .plan-feature svg { flex-shrink: 0; width: 14px; height: 14px; margin-top: 2px; fill: none; stroke: rgba(255,255,255,0.3); stroke-width: 2; stroke-linecap: round; }
    .plan.featured .plan-feature svg { stroke: var(--purple); }

    .plan-cta {
      display: block; text-align: center; font-size: 0.85rem; font-weight: 600;
      padding: 0.8rem; border-radius: 10px;
      text-decoration: none; transition: all 0.2s;
      border: 1px solid var(--glass-b); color: rgba(255,255,255,0.7); background: var(--glass);
    }
    .plan-cta:hover { background: var(--glass-h); color: white; border-color: var(--faint); }
    .plan.featured .plan-cta { background: white; color: var(--bg); border-color: white; }
    .plan.featured .plan-cta:hover { opacity: 0.88; }

    /* ── TESTIMONIALS ── */
    #testimonial { background: var(--bg); }
    .test-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .test-card {
      background: var(--glass); border: 1px solid var(--glass-b);
      backdrop-filter: blur(20px); border-radius: 20px; padding: 2.2rem;
      transition: background 0.25s, border-color 0.25s, transform 0.25s;
    }
    .test-card:hover { background: var(--glass-h); border-color: var(--faint); transform: translateY(-3px); }
    .test-card.large { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center; }
    .test-stars { display: flex; gap: 3px; margin-bottom: 1.2rem; }
    .test-stars svg { width: 13px; height: 13px; fill: rgba(191,128,255,0.6); }
    .test-quote { font-size: 0.92rem; font-weight: 300; line-height: 1.75; color: rgba(255,255,255,0.65); margin-bottom: 1.5rem; font-style: italic; }
    .test-large-quote { font-family: 'DM Serif Display', serif; font-size: 1.4rem; font-weight: 400; line-height: 1.4; color: white; margin-bottom: 1.5rem; }
    .test-author { display: flex; align-items: center; gap: 0.8rem; }
    .test-av { width: 36px; height: 36px; border-radius: 50%; background: rgba(191,128,255,0.12); border: 1px solid rgba(191,128,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 700; color: var(--purple); }
    .test-name { font-size: 0.83rem; font-weight: 600; color: white; }
    .test-role { font-size: 0.72rem; color: var(--muted); margin-top: 1px; }

    /* ── CTA ── */
    #cta { background: var(--bg2); position: relative; overflow: hidden; }
    #cta::before {
      content: ''; position: absolute; width: 700px; height: 700px; border-radius: 50%;
      background: radial-gradient(circle, rgba(191,128,255,0.06) 0%, transparent 70%);
      top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none;
    }
    .cta-inner { max-width: 680px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
    .cta-inner .sec-h2 { font-size: clamp(2rem,5vw,3.8rem); margin-bottom: 1rem; }
    .cta-inner .sec-p { margin: 0 auto 2.5rem; }
    .cta-logo { height: 60px; width: auto; margin: 0 auto 2.5rem; display: block; filter: brightness(1.1); }
    .cta-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }

    /* ── FOOTER ── */
    footer { background: var(--bg); border-top: 1px solid var(--glass-b); padding: 4rem 6% 2.5rem; }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; padding-bottom: 3rem; border-bottom: 1px solid var(--glass-b); }
    .footer-logo { height: 40px; width: auto; margin-bottom: 1rem; filter: brightness(1.1); }
    .footer-desc { font-size: 0.84rem; font-weight: 300; color: var(--muted); line-height: 1.7; max-width: 240px; }
    .footer-col-title { font-size: 0.68rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.2rem; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
    .footer-col ul a { font-size: 0.82rem; font-weight: 300; color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .footer-col ul a:hover { color: white; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer-bottom p { font-size: 0.74rem; color: rgba(255,255,255,0.2); }
    .footer-socials { display: flex; gap: 0.5rem; }
    .fs { width: 32px; height: 32px; border-radius: 7px; background: var(--glass); border: 1px solid var(--glass-b); display: flex; align-items: center; justify-content: center; color: var(--muted); text-decoration: none; font-size: 0.72rem; transition: all 0.2s; }
    .fs:hover { background: rgba(255,255,255,0.1); color: white; border-color: var(--faint); }

    /* ── SCROLL REVEAL ── */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.65s ease, transform 0.65s ease; }
    .reveal.in { opacity: 1; transform: none; }
    .d1 { transition-delay: 0.1s; } .d2 { transition-delay: 0.2s; } .d3 { transition-delay: 0.3s; }

    .back-top { position: fixed; bottom: 2rem; right: 2rem; z-index: 50; width: 40px; height: 40px; border-radius: 10px; background: var(--glass); border: 1px solid var(--glass-b); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; font-size: 1rem; color: var(--muted); text-decoration: none; opacity: 0; pointer-events: none; transform: translateY(8px); transition: opacity 0.3s, transform 0.2s, color 0.2s; }
    .back-top.visible { opacity: 1; pointer-events: auto; transform: none; }
    .back-top:hover { color: white; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      .sol-intro { grid-template-columns: 1fr; }
      .how-steps { grid-template-columns: 1fr 1fr; }
      .how-steps::before { display: none; }
      .pricing-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
      .metrics-inner { grid-template-columns: 1fr 1fr; }
      .test-layout { grid-template-columns: 1fr; }
      .test-card.large { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 700px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .nav-links.open { display: flex; flex-direction: column; position: absolute; top: 68px; left: 0; right: 0; background: rgba(4,4,8,0.98); backdrop-filter: blur(20px); border-bottom: 1px solid var(--glass-b); padding: 1.5rem 6%; }
      .nav-links.open li { padding: 0.75rem 0; border-bottom: 1px solid var(--glass-b); }
      .problem-grid { grid-template-columns: 1fr; }
      .how-steps { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr; }
      section { padding: 5rem 5%; }
      .hero-logo { height: 60px; }
      .hero-h1 { font-size: 2.6rem; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#hero" class="nav-logo">
    <img src="logo.png" alt="BOD — CFO Virtual" class="nav-logo-img"/>
  </a>
  <ul class="nav-links" id="navLinks">
    <li><a href="#solution">Solución</a></li>
    <li><a href="#how">Metodología</a></li>
    <li><a href="#testimonial">Testimonios</a></li>
    <li><a href="#cta" class="nav-cta">Comenzar Gratis</a></li>
  </ul>
  <div class="hamburger" id="hamburger" role="button" tabindex="0" aria-label="Menu">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- HERO — AetherFlow Particle Canvas -->
<section id="hero">
  <canvas id="particle-canvas"></canvas>

  <div class="hero-content">
    <div class="hero-badge fade-up fade-up-1">
      <div class="hero-badge-dot"></div>
